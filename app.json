{
  "expo": {
    "name": "proy_ayudas",
    "slug": "proy_ayudas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBFAF7"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.proy_ayudas"
    },
    "web": {
      "favicon": "./assets/icon.png",
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FBFAF7"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1B5E4A"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "36be66e4-57bf-4e41-9629-528894f6aa5b"
      }
    },
    "owner": "mauricio_ortunho_quispe"
  }
}
